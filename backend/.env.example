# ─── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskdb
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ─── JWT ─────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64,(e,b)=>console.log(b.toString('hex')))"
JWT_SECRET=REPLACE_WITH_A_STRONG_128_CHAR_HEX_SECRET
JWT_EXPIRES_IN=7d

# ─── Security ────────────────────────────────────────────
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
